DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/giveaway
PORT=3000
# development | production | test
NODE_ENV=development
# Backend public base URL (used for OAuth callback fallback)
APP_BASE_URL=http://localhost:3000
# Frontend public base URL (Next.js dev server runs on 3001 in this repo)
WEB_BASE_URL=http://localhost:3001
# Frontend origin allowed to call backend APIs
CORS_ORIGIN=http://localhost:3001
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
# Optional: if empty, uses ${APP_BASE_URL}/api/auth/callback
DISCORD_OAUTH_REDIRECT_URI=
