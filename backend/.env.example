DISCORD_BOT_TOKEN=
DISCORD_APP_ID=
DISCORD_GUILD_ID=
DATABASE_URL=postgres://postgres:postgres@localhost:5432/giveaway
PORT=3000
# Optional local override. NODE_ENV value: development | production | test
NODE_ENV=development
# Backend public base URL (used to build OAuth callback URL when DISCORD_OAUTH_REDIRECT_URI is not set)
APP_BASE_URL=http://localhost:3000
# Frontend public base URL (Next.js dev server runs on 5173 in this repo)
WEB_BASE_URL=http://localhost:5173
# Frontend origin allowed to call backend APIs
CORS_ORIGIN=http://localhost:5173
DISCORD_OAUTH_CLIENT_ID=
DISCORD_OAUTH_CLIENT_SECRET=
# Optional: if empty, uses ${APP_BASE_URL}/api/auth/callback
DISCORD_OAUTH_REDIRECT_URI=
