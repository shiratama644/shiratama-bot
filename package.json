{
  "name": "applejp-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm --filter backend build && pnpm --filter web build",
    "dev": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter web dev",
    "dev:all": "concurrently -n backend,web -c blue,magenta \"pnpm dev\" \"pnpm dev:web\"",
    "test": "pnpm --filter backend build && node --test _test_/*.test.mjs && pnpm --filter backend test",
    "lint": "pnpm --filter backend lint && pnpm --filter web lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiratama644/applejp-bot.git"
  },
  "keywords": [],
  "author": "",
