{
  "name": "shiratama-bot",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "pnpm --filter backend build && pnpm --filter web build",
    "dev": "pnpm --filter backend dev",
    "dev:web": "pnpm --filter web dev",
    "dev:all": "concurrently -n backend,web -c blue,magenta \"pnpm dev\" \"pnpm dev:web\"",
    "test": "pnpm --filter backend build && node --test _test_/**/*.test.mjs && pnpm --filter backend test",
    "lint": "pnpm --filter backend lint && pnpm --filter web lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiratama644/shiratama-bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/shiratama644/shiratama-bot/issues"
  },
  "homepage": "https://github.com/shiratama644/shiratama-bot#readme",
  "private": true,
  "workspaces": [
    "backend",
    "web"
  ],
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
